{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "types": ["node"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noImplicitAny": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "convex/_generated/api": ["./_generated/api"],
      "convex/_generated/server": ["./_generated/server"],
      "convex/_generated/dataModel": ["./_generated/dataModel"]
    }
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules", "_generated"]
}
