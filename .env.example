# Convex
NEXT_PUBLIC_CONVEX_URL=https://<deployment-name>.convex.cloud
CONVEX_DEPLOY_KEY=

# Better Auth
BETTER_AUTH_SECRET=<random-32-char-string>
BETTER_AUTH_URL=https://<your-domain>/api/auth

# Google OAuth (D2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (D2 — optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Resend (password reset, email verify — FR5)
RESEND_API_KEY=

# Cloudflare R2 (D10 — files > 5MB)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ACCOUNT_ID=

# Backblaze B2 (D10 — backup)
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_ID=
B2_BUCKET_NAME=

# Google Drive backup (FR50)
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
